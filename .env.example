# .env.example
# Copy to .env only if you want to override the defaults below.
# A fresh clone runs end-to-end with `docker compose up --build -d` and
# no .env file at all — every value here has a working default in
# docker-compose.yml.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-key-change-me-before-anything-public
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Set to 0 to skip the demo seed on a fresh database.
DJANGO_AUTO_SEED=1

# --- Database ---
POSTGRES_DB=ijara
POSTGRES_USER=ijara
POSTGRES_PASSWORD=ijara_dev

# --- Git SHA (shown in /api/v1/health/) ---
GIT_SHA=unknown

# --- Nuxt ---
# Server-side base URL: used by Nuxt's Nitro server inside the Docker
# network. Do not point this at localhost.
NUXT_API_BASE_SERVER=http://api:8000/api/v1/
# Public base URL: used by browser JavaScript after hydration.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1/

# Absolute origin the browser can reach Django at. Serializers use this
# when building absolute photo URLs.
DJANGO_MEDIA_HOST=http://localhost:8000

# --- Stripe (test keys — replace with your own to exercise checkout) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
